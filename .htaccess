# =====================================================
#  FITRONFITNESS — URL rewriting
#  Requires Apache mod_rewrite (enabled on virtually all
#  shared hosting). If these pretty URLs don't work on
#  your host, set USE_PRETTY_URLS to false in
#  includes/config.php and the site will use
#  category.php?slug=... / product.php?slug=... instead.
# =====================================================
RewriteEngine On

# /category/indoor-gym-equipment  ->  category.php?slug=indoor-gym-equipment
RewriteRule ^category/([a-zA-Z0-9_-]+)/?$ category.php?slug=$1 [L,QSA]

# /product/vertical-chest-press  ->  product.php?slug=vertical-chest-press
RewriteRule ^product/([a-zA-Z0-9_-]+)/?$ product.php?slug=$1 [L,QSA]

# Sensible default document
DirectoryIndex index.php

# If your host uses classic mod_php (not PHP-FPM), you can uncomment
# the two lines below to hide PHP error output from visitors once the
# site is live and tested:
# <IfModule mod_php7.c>
#   php_flag display_errors off
# </IfModule>
